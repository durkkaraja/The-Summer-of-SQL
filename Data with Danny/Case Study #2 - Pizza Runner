-- How many Vegetarian and Meatlovers were ordered by each customer?
with cte as (
    select customer_id
        ,pizza_name
        ,1 as pizza_count
    from customer_orders
    join pizza_names on customer_orders.pizza_id=pizza_names.pizza_id
)

select *
from cte
pivot(sum(pizza_count)
for pizza_name in ('Meatlovers','Vegetarian')
) as pvt;


-- B. Runner and Customer Expererience

-- How many runners signed up for each 1 week period? (i.e. week starts 2021-01-01)
select
    dateadd(
        'day',
        floor(datediff('day','2021-01-01'::date,registration_date) / 7) * 7,
        '2021-01-01'::date
    ) as week_commencing
    ,count(runner_id) as runner_signups
from runners
where registration_date >= '2021-01-01'
group by 1 
order by 1;

-- What was the average time in minutes it took for each runner to arrive at the Pizza Runner HQ to pickup the order?
with cte as (
    select runner_id
        ,datediff('minute', min(order_time), pickup_time) as diff
    from customer_orders as c
    join runner_orders as r on c.order_id = r.order_id
    where lower(pickup_time) != 'null'
    group by runner_id
        ,pickup_time
)

select runner_id
    ,round(avg(diff),2) as avg_minutes
from cte
group by runner_id
order by runner_id;